NODE_ENV=

# DATABASE (Postgres)
DATABASE_URL=
# Push mode auto-syncs the schema in dev (no migrations). Set false in prod.
DEV_DB_PUSH=true
PAYLOAD_SECRET=

# AUTH (GitHub OAuth + Auth.js)
# Create a GitHub OAuth app at https://github.com/settings/developers
# Authorization callback URL: <AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Optional comma-separated extra super-admin emails (bob@bbass.co is hardcoded)
SUPER_ADMIN_EMAILS=

# FILE STORAGE (Vercel Blob — used for blog featured images + avatars)
BLOB_PREFIX=
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
